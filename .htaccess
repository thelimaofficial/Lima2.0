# ============================
# .htaccess — Remover .html das URLs
# Ambiente: Apache (Locaweb Linux)
# ============================

# Evita conflitos com MultiViews (Directory negotiation)
Options -MultiViews

# Página inicial padrão
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  # Se seu site estiver em uma SUBPASTA, descomente e ajuste a base:
  # Ex.: se o site estiver em https://seu-dominio.com/site, use: RewriteBase /site/
  #RewriteBase /

  # [1] Redireciona /pagina.html -> /pagina  (SEO/canonical)
  # Usa a linha de requisição original para detectar .html digitado na URL
  RewriteCond %{THE_REQUEST} \s/+(.+)\.html[\s?] [NC]
  RewriteRule ^ /%1 [R=301,L]

  # [2] Se não for arquivo nem pasta real, mas existir um .html correspondente,
  # serve o arquivo (permite acessar /pagina que carrega pagina.html)
  RewriteCond %{REQUEST_FILENAME} !-d
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME}.html -f
  RewriteRule ^(.+)$ $1.html [L]
</IfModule>

# ===== OPCIONAIS (descomente se quiser aplicar) =====
